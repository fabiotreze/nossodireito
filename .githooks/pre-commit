#!/bin/sh
# NossoDireito — Pre-commit Hook (minimal)
# Gates locais: gitleaks (segredos) + docs-truth (drift de documentação).
# Skip manual: git commit --no-verify

if command -v gitleaks > /dev/null 2>&1; then
    gitleaks protect --staged --redact --no-banner 2>&1 || {
        echo "  BLOQUEADO: segredos detectados pelo gitleaks."
        echo "  Skip: git commit --no-verify (apenas falsos positivos)."
        exit 1
    }
fi

# Docs truth + link guard — rápidos (~100ms), pegam drift cedo.
if command -v node > /dev/null 2>&1; then
    node scripts/check_doc_links.mjs > /dev/null || {
        echo "  BLOQUEADO: link relativo quebrado em docs (rode 'npm run check:docs')."
        exit 1
    }
    node scripts/check_docs_truth.mjs > /dev/null || {
        echo "  BLOQUEADO: docs citam feature removida (rode 'npm run check:docs')."
        exit 1
    }
fi

exit 0
