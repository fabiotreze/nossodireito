#!/bin/sh
# NossoDireito — Pre-commit Hook (Quality Gate)
#
# Instalacao automatica via 'npm install' (script 'prepare' seta core.hooksPath).
# Manual: git config core.hooksPath .githooks
#
# Comando unico: master_compliance.py --quick (~6s)
# Inclui internamente:
#   - Fail-fast de versao (aborta se inconsistente entre manifest/sw/data/*.json)
#   - JSON Schema Draft 7
#   - 21 categorias de validacao (~1050 pts)
#   - Pula HTTP/fontes (modo rapido)
#
# Skip automatico: diffs SO de documentacao (.md/.txt) pulam o validator pesado.
# Checks pesados (testes Node, semver gate, SW cache gate) rodam no pre-push.
# Para pular manualmente: git commit --no-verify (use com motivo no msg).

# Se diff so toca docs/*.md: roda apenas Cat-5 (headers + mermaid + freshness, ~1s).
# Para qualquer outro arquivo: roda --quick completo (~30s).
non_docs=$(git diff --cached --name-only --diff-filter=ACMR | grep -vE '\.(md|txt)$' || true)
docs_changed=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '^docs/.*\.md$' || true)
if [ -z "$non_docs" ]; then
    if [ -n "$docs_changed" ]; then
        echo "📝 pre-commit: diff so de docs — validando headers/mermaid/freshness (Cat-5)..."
        if command -v python > /dev/null 2>&1; then PYTHON=python; elif command -v python3 > /dev/null 2>&1; then PYTHON=python3; else exit 0; fi
        $PYTHON scripts/master_compliance.py --docs-only || { echo "  BLOQUEADO: documentacao fora do padrao."; exit 1; }
    else
        echo "📝 pre-commit: diff so de .md/.txt nao-doc — pulando validator."
    fi
    exit 0
fi

echo ""
echo "======================================================"
echo "  Pre-commit Quality Gate -- NossoDireito"
echo "======================================================"
echo ""

# Detectar Python (prefere 'python' no Windows para evitar Store alias)
if command -v python > /dev/null 2>&1; then
    PYTHON=python
elif command -v python3 > /dev/null 2>&1; then
    PYTHON=python3
else
    echo "  WARN: Python nao encontrado -- pulando Quality Gate."
    exit 0
fi

$PYTHON scripts/master_compliance.py --quick

# Freshness das fontes jurídicas (warning, não bloqueia)
$PYTHON scripts/check_sources_freshness.py || true
RESULT=$?

echo ""
echo "======================================================"
if [ $RESULT -ne 0 ]; then
    echo "  BLOQUEADO -- Quality Gate falhou."
    echo "  Corrija os problemas acima e tente novamente."
    echo "  Para pular: git commit --no-verify"
    echo "======================================================"
    echo ""
    exit 1
fi

echo "  OK -- Quality Gate COMPLETO -- commit permitido."
echo "======================================================"
echo ""
exit 0
