{
  "name": "nossodireito",
  "version": "1.33.2",
  "description": "NossoDireito — Portal de direitos PcD (server)",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "test": "python -m pytest tests/ -v --tb=short --ignore=tests/test_browser.py",
    "test:js": "node --test tests/*.test.mjs",
    "validate": "python scripts/validate_all.py --quick",
    "security:headers": "bash scripts/security_headers_check.sh",
    "replication:bootstrap": "bash scripts/bootstrap_replication.sh --help",
    "prepare": "node scripts/setup-hooks.mjs"
  },
  "dependencies": {
    "@azure/identity": "^4.13.1",
    "@azure/keyvault-secrets": "^4.9.0",
    "@azure/monitor-opentelemetry": "^1.18.0",
    "applicationinsights": "^3.14.0",
    "openai": "^6.39.0",
    "redis": "^5.9.0"
  },
  "engines": {
    "node": ">=22"
  },
  "private": true,
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "clean-css-cli": "^5.6.3",
    "html-minifier-terser": "^7.2.0",
    "playwright": "^1.60.0",
    "terser": "^5.45.1"
  },
  "overrides": {
    "protobufjs": "^7.5.4",
    "uuid": "^11.1.1"
  }
}
